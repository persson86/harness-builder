# Ignore everything
*

# Track package metadata and installer
!.gitignore
!README.md
!VERSION
!install.sh

# Track the installable harness payload
!payload/
!payload/**
payload/**/.DS_Store

# Track project-owned templates copied outside the payload manifest
!templates/
!templates/**
templates/**/.DS_Store

# Track personal (non-payload) bridge config — versioned, not installed, not in README
!personal/
!personal/**
personal/**/.DS_Store
